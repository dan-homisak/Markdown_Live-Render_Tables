{
  "name": "markdown-live-render-tables",
  "displayName": "Markdown Live Editor",
  "description": "A VS Code extension for editing markdown in a live rendered editor.",
  "version": "0.1.138",
  "publisher": "dan-homisak",
  "license": "MIT",
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "markdownLiveRenderTables.toggleEditor",
        "title": "Toggle Markdown Live Editor",
        "category": "Markdown Live Editor",
        "icon": "$(eye)"
      },
      {
        "command": "markdownLiveRenderTables.showDebugLog",
        "title": "Show Debug Log",
        "category": "Markdown Live Editor"
      }
    ],
    "keybindings": [
      {
        "command": "markdownLiveRenderTables.toggleEditor",
        "key": "ctrl+alt+m",
        "mac": "cmd+ctrl+m"
      }
    ],
    "configuration": {
      "title": "Markdown Live Editor",
      "properties": {
        "markdownLiveRenderTables.debug": {
          "type": "boolean",
          "default": false,
          "description": "Write live editor cursor, focus, and source edit diagnostics to the Markdown Live Editor output channel."
        },
        "markdownLiveRenderTables.tableNavigation.modifierKey": {
          "type": "string",
          "scope": "window",
          "enum": [
            "F1",
            "F2",
            "F3",
            "F4",
            "F5",
            "F6",
            "F7",
            "F8",
            "F9",
            "F10",
            "F11",
            "F12"
          ],
          "default": "F2",
          "markdownDescription": "The function key to hold while pressing an unmodified arrow key to move directly to an adjacent rendered table cell. The caret is placed at the end of the destination cell. This applies only while editing a table cell."
        },
        "markdownLiveRenderTables.clipboard.defaultCopyMode": {
          "type": "string",
          "enum": [
            "smart",
            "rich",
            "plain",
            "markdown"
          ],
          "default": "smart",
          "description": "Default representation used by Copy in the Markdown Live Editor. Smart publishes clean HTML, a Markdown table fallback for plain-text consumers, and a lossless internal payload."
        },
        "markdownLiveRenderTables.clipboard.defaultPasteMode": {
          "type": "string",
          "enum": [
            "auto",
            "rich",
            "plain",
            "markdown"
          ],
          "default": "auto",
          "description": "Default interpretation used by Paste in the Markdown Live Editor. Automatic prefers lossless internal data, then HTML, Markdown, and plain text."
        }
      }
    },
    "customEditors": [
      {
        "viewType": "markdownLiveRenderTables.liveEditor",
        "displayName": "Markdown Live Editor",
        "selector": [
          {
            "filenamePattern": "*.md"
          },
          {
            "filenamePattern": "*.markdown"
          }
        ],
        "priority": "option"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "markdownLiveRenderTables.toggleEditor",
          "when": "resourceExtname == .md || resourceExtname == .markdown",
          "group": "navigation@1"
        }
      ]
    }
  },
  "scripts": {
    "bundle:webview": "esbuild src/webview/liveEditor.ts --bundle --format=iife --platform=browser --target=es2022 --outfile=media/liveEditor.js",
    "compile": "tsc -p ./ && npm run bundle:webview",
    "package": "vsce package --allow-missing-repository --out markdown-live-render-tables-latest.vsix",
    "package:windows": "npm run package && node scripts/prepare-windows-install-bundle.mjs",
    "qa:harness": "npm run compile && node scripts/render-live-editor-harness.mjs",
    "qa:cursor": "npm run compile && node scripts/render-live-editor-harness.mjs --debug",
    "qa:screenshot": "npm run compile && node scripts/render-live-editor-harness.mjs --screenshot",
    "qa:clipboard": "npm run compile && node scripts/edh-visual-check.mjs",
    "qa:editing": "npm run compile && node scripts/edh-visual-check.mjs --editing-reliability-only",
    "qa:keyboard": "npm run compile && node scripts/edh-visual-check.mjs --keyboard-navigation-only",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./dist/test/smoke.test.js && node ./dist/test/clipboard.test.js && node ./dist/test/selection.test.js && node ./dist/test/sourceProtection.test.js && node ./dist/test/tableCellInput.test.js && node ./dist/test/tableKeyboardNavigation.test.js && node ./dist/test/documentChangeValidation.test.js && node ./dist/test/tableParserReliability.test.js && node ./dist/test/tableEditingReliability.test.js",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.4",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.0.8",
    "@types/turndown": "^5.0.6",
    "@types/vscode": "^1.101.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "dompurify": "^3.4.11",
    "markdown-it": "^14.3.0",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2"
  }
}
