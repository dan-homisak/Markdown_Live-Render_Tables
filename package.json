{
  "name": "markdown-live-render-tables",
  "displayName": "Markdown Live Editor",
  "description": "A VS Code extension for editing markdown in a live rendered editor.",
  "version": "0.1.26",
  "publisher": "dan-homisak",
  "license": "MIT",
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:markdown",
    "onCustomEditor:markdownLiveRenderTables.liveEditor",
    "onCustomEditor:markdownLiveRenderTables.tableEditor"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "markdownLiveRenderTables.toggleEditor",
        "title": "Toggle Markdown Live Editor",
        "category": "Markdown Live Editor",
        "icon": "$(eye)"
      },
      {
        "command": "markdownLiveRenderTables.showDebugLog",
        "title": "Show Debug Log",
        "category": "Markdown Live Editor"
      }
    ],
    "keybindings": [
      {
        "command": "markdownLiveRenderTables.toggleEditor",
        "key": "ctrl+alt+m",
        "mac": "cmd+ctrl+m"
      }
    ],
    "configuration": {
      "title": "Markdown Live Editor",
      "properties": {
        "markdownLiveRenderTables.debug": {
          "type": "boolean",
          "default": false,
          "description": "Write live editor cursor, focus, and source edit diagnostics to the Markdown Live Editor output channel."
        }
      }
    },
    "customEditors": [
      {
        "viewType": "markdownLiveRenderTables.liveEditor",
        "displayName": "Markdown Live Editor",
        "selector": [
          {
            "filenamePattern": "*.md"
          },
          {
            "filenamePattern": "*.markdown"
          }
        ],
        "priority": "option"
      },
      {
        "viewType": "markdownLiveRenderTables.tableEditor",
        "displayName": "Markdown Live Editor (Legacy)",
        "selector": [
          {
            "filenamePattern": "*.md"
          },
          {
            "filenamePattern": "*.markdown"
          }
        ],
        "priority": "option"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "markdownLiveRenderTables.toggleEditor",
          "when": "resourceExtname == .md || resourceExtname == .markdown",
          "group": "navigation@1"
        }
      ]
    }
  },
  "scripts": {
    "bundle:webview": "esbuild src/webview/liveEditor.ts --bundle --format=iife --platform=browser --target=es2022 --outfile=media/liveEditor.js && esbuild src/webview/tableEditor.ts --bundle --format=iife --platform=browser --target=es2022 --outfile=media/tableEditor.js",
    "compile": "tsc -p ./ && npm run bundle:webview",
    "package": "vsce package --allow-missing-repository --out markdown-live-render-tables-latest.vsix",
    "qa:harness": "npm run compile && node scripts/render-live-editor-harness.mjs",
    "qa:cursor": "npm run compile && node scripts/render-live-editor-harness.mjs --debug",
    "qa:screenshot": "npm run compile && node scripts/render-live-editor-harness.mjs --screenshot",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./dist/test/smoke.test.js",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.4",
    "@types/node": "^24.0.8",
    "@types/vscode": "^1.101.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "typescript": "^5.8.3"
  }
}
