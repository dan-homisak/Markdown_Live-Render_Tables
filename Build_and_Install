#!/bin/zsh
set -euo pipefail
setopt NULL_GLOB

PROJECT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$PROJECT_DIR"

pause_if_clicked() {
  if [[ -t 0 ]]; then
    echo
    echo "Press any key to close this window."
    read -k 1 -s || true
  fi
}

trap pause_if_clicked EXIT

log() {
  echo
  echo "==> $1"
}

find_code_cli() {
  if command -v code >/dev/null 2>&1; then
    command -v code
    return 0
  fi

  local stable="/Applications/Visual Studio Code.app/Contents/Resources/app/bin/code"
  if [[ -x "$stable" ]]; then
    echo "$stable"
    return 0
  fi

  local insiders="/Applications/Visual Studio Code - Insiders.app/Contents/Resources/app/bin/code"
  if [[ -x "$insiders" ]]; then
    echo "$insiders"
    return 0
  fi

  return 1
}

CODE_CLI="$(find_code_cli)" || {
  echo "Could not find the VS Code CLI."
  echo "Install VS Code or run 'Shell Command: Install code command in PATH' from VS Code."
  exit 1
}

VSIX_PATH="$PROJECT_DIR/markdown-live-render-tables-latest.vsix"
EXTENSION_ID="dan-homisak.markdown-live-render-tables"
EXPECTED_VERSION="$(node -p "require('./package.json').version")"

log "Using VS Code CLI"
"$CODE_CLI" --version

log "Cleaning generated build outputs"
rm -rf "$PROJECT_DIR/dist"
rm -f "$PROJECT_DIR"/*.vsix

log "Bumping patch version so VS Code sees a genuine update"
PREVIOUS_VERSION="$EXPECTED_VERSION"
npm version patch --no-git-tag-version >/dev/null
EXPECTED_VERSION="$(node -p "require('./package.json').version")"
echo "Version: ${PREVIOUS_VERSION} -> ${EXPECTED_VERSION}"

log "Installing dependencies from package-lock.json"
npm ci

log "Building and packaging extension"
npm run package

if [[ ! -f "$VSIX_PATH" ]]; then
  echo "Expected package was not created: $VSIX_PATH"
  exit 1
fi

log "Uninstalling previously installed extension, if present"
"$CODE_CLI" --uninstall-extension "$EXTENSION_ID" || true

log "Removing stale installed extension directories"
STALE_EXTENSION_DIRS=("$HOME/.vscode/extensions/${EXTENSION_ID}-"*)
if (( ${#STALE_EXTENSION_DIRS[@]} > 0 )); then
  rm -rf "${STALE_EXTENSION_DIRS[@]}"
  printf 'Removed %d stale extension directorie(s).\n' "${#STALE_EXTENSION_DIRS[@]}"
else
  echo "No stale extension directories found."
fi

log "Installing latest VSIX into VS Code"
"$CODE_CLI" --install-extension "$VSIX_PATH" --force

log "Verifying installed extension version"
INSTALLED_VERSION="$("$CODE_CLI" --list-extensions --show-versions | awk -F@ -v id="$EXTENSION_ID" '$1 == id { print $2 }' | tail -n 1)"
if [[ "$INSTALLED_VERSION" != "$EXPECTED_VERSION" ]]; then
  echo "Expected $EXTENSION_ID@$EXPECTED_VERSION but found ${INSTALLED_VERSION:-not installed}."
  exit 1
fi
echo "Verified: $EXTENSION_ID@$INSTALLED_VERSION"

INSTALLED_DIR="$HOME/.vscode/extensions/${EXTENSION_ID}-${EXPECTED_VERSION}"
if [[ ! -d "$INSTALLED_DIR" ]]; then
  echo "Expected installed extension directory was not found: $INSTALLED_DIR"
  exit 1
fi
if ! grep -q "formatTableCellSourceEdit" "$INSTALLED_DIR/media/liveEditor.js"; then
  echo "Installed webview bundle does not contain the expected source-span edit marker."
  exit 1
fi
if ! grep -q "ignored a change without source ranges" "$INSTALLED_DIR/dist/extension.js"; then
  echo "Installed extension host does not contain the expected full-document fallback guard."
  exit 1
fi
if ! grep -q "reopenActiveEditorWith" "$INSTALLED_DIR/dist/extension.js"; then
  echo "Installed extension host does not contain the expected active editor reopen marker."
  exit 1
fi
if ! grep -q "hiddenLineNumberMarker" "$INSTALLED_DIR/media/liveEditor.js"; then
  echo "Installed webview bundle does not contain the expected table gutter suppression marker."
  exit 1
fi
if ! grep -q "table-layout: fixed" "$INSTALLED_DIR/media/liveEditor.css"; then
  echo "Installed webview stylesheet does not contain the fixed table-layout marker."
  exit 1
fi
if ! grep -q "mm-live-v4-table-source-line" "$INSTALLED_DIR/media/liveEditor.css"; then
  echo "Installed webview stylesheet does not contain the table row line-number marker."
  exit 1
fi
if ! grep -q "mlrt-live-content-width" "$INSTALLED_DIR/media/liveEditor.css"; then
  echo "Installed webview stylesheet does not contain the live table width marker."
  exit 1
fi
if ! grep -q "createEditorGeometrySync" "$INSTALLED_DIR/media/liveEditor.js"; then
  echo "Installed webview bundle does not contain the editor geometry sync marker."
  exit 1
fi
if ! grep -q "appendColumnSizing" "$INSTALLED_DIR/media/liveEditor.js"; then
  echo "Installed webview bundle does not contain the table column sizing marker."
  exit 1
fi
if ! grep -q "measureTableColumnSizing" "$INSTALLED_DIR/media/liveEditor.js"; then
  echo "Installed webview bundle does not contain the proportional table column sizing marker."
  exit 1
fi
if ! grep -q "measureAvailableDataWidthCh" "$INSTALLED_DIR/media/liveEditor.js"; then
  echo "Installed webview bundle does not contain dynamic table column width measurement."
  exit 1
fi
echo "Verified installed payload markers."

log "Reloading the VS Code window(s) for this project"
PROJECT_NAME="$(basename "$PROJECT_DIR")"
RELOAD_OK=0
if [[ "${SKIP_RELOAD:-0}" == "1" ]]; then
  echo "SKIP_RELOAD=1 set; not reloading. Run 'Developer: Reload Window' to apply the new build."
elif command -v osascript >/dev/null 2>&1; then
  if osascript - "$PROJECT_NAME" 2>/dev/null <<'APPLESCRIPT'
on run argv
  set targetName to item 1 of argv
  tell application "Visual Studio Code" to activate
  delay 0.3
  tell application "System Events"
    if not (exists process "Code") then error "VS Code process was not found."
    tell process "Code"
      set reloadedCount to 0
      repeat with w in windows
        if (name of w) contains targetName then
          perform action "AXRaise" of w
          delay 0.2
          keystroke "p" using {command down, shift down}
          delay 0.3
          keystroke ">Developer: Reload Window"
          delay 0.2
          key code 36
          set reloadedCount to reloadedCount + 1
          delay 0.5
        end if
      end repeat
      if reloadedCount is 0 then error "No VS Code window for this project was found."
    end tell
  end tell
end run
APPLESCRIPT
  then
    RELOAD_OK=1
    echo "Reloaded the VS Code window(s) titled with '$PROJECT_NAME'."
  else
    echo "Automatic reload was skipped or blocked (Accessibility permission or no matching window)."
  fi
else
  echo "osascript is unavailable; automatic reload skipped."
fi

log "Done"
echo "Installed: $VSIX_PATH"

if (( RELOAD_OK == 0 )) && [[ "${SKIP_RELOAD:-0}" != "1" ]]; then
  cat <<BANNER

========================================================================
  ACTION REQUIRED: could not auto-reload your VS Code window.

  Because the version was bumped to ${EXPECTED_VERSION}, VS Code will
  show a "reload to update" prompt automatically -- click it.

  Or run it yourself in the project window:
    Developer: Reload Window   (Cmd+R)

  To enable fully automatic reloads, grant Accessibility permission to
  your terminal:
  System Settings > Privacy & Security > Accessibility > enable your
  terminal app (Terminal / iTerm / VS Code).
========================================================================

BANNER
fi
